@{
    ViewData["Title"] = "إدارة الموظفين";
}

<div class="erp-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success erp-alert">@TempData["Success"]</div>
    }

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الموارد البشرية</p>
            <h1>@ViewData["Title"]</h1>
            <p class="erp-table-note">تابع بيانات الموظفين والرواتب والحالة التشغيلية من شاشة واحدة.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-person-plus"></i> إضافة موظف جديد
            </a>
        </div>
    </div>

    <section class="erp-panel">
        <div class="erp-panel-header">
            <div>
                <h2>قائمة الموظفين</h2>
                <p class="erp-table-note">يمكنك البحث بالاسم أو الهاتف أو الوظيفة.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle erp-data-table" id="employeesTable" style="width:100%">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الوظيفة</th>
                        <th>رقم الهاتف</th>
                        <th class="erp-number">الراتب</th>
                        <th>تاريخ التعيين</th>
                        <th>الحالة</th>
                        <th class="text-center">العمليات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#employeesTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/Employee/LoadData",
                    "type": "POST"
                },
                "columns": [
                    { "data": "name" },
                    { "data": "position", "defaultContent": "---" },
                    { "data": "phone", "defaultContent": "---" },
                    {
                        "data": "salary",
                        "className": "erp-number",
                        "render": function(data) {
                            return new Intl.NumberFormat('ar-EG', { style: 'currency', currency: 'EGP' }).format(data || 0);
                        }
                    },
                    {
                        "data": "hireDate",
                        "render": function(data) {
                            return data ? new Date(data).toLocaleDateString('ar-EG') : "---";
                        }
                    },
                    {
                        "data": "isActive",
                        "render": function(data) {
                            return data
                                ? '<span class="erp-status-pill erp-status-pill-success">نشط</span>'
                                : '<span class="erp-status-pill erp-status-pill-danger">غير نشط</span>';
                        }
                    },
                    {
                        "data": "id",
                        "render": function (data, type, row) {
                            const editButton = `<a href="/Employee/Edit/${data}" class="btn btn-outline-warning btn-sm">تعديل</a>`;
                            const disableButton = row.isActive
                                ? `<a href="/Employee/Delete/${data}" class="btn btn-outline-danger btn-sm">تعطيل</a>`
                                : '';

                            return `<div class="erp-table-actions">${editButton}${disableButton}</div>`;
                        },
                        "orderable": false,
                        "searchable": false
                    }
                ],
                "language": window.erpDataTablesArabic
            });
        });
    </script>
}
