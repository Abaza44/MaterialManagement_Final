@model ErrorViewModel
@{
    ViewData["Title"] = "حدث خطأ";
}

<div class="erp-page erp-review-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">النظام</p>
            <h1>حدث خطأ أثناء تنفيذ الطلب</h1>
            <p class="erp-table-note">لم يكتمل الطلب الحالي. يمكنك الرجوع وإعادة المحاولة أو فتح لوحة التحكم.</p>
        </div>
        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">لوحة التحكم</a>
    </div>

    <section class="erp-panel erp-danger-zone">
        <div class="erp-panel-header"><h2>تفاصيل المراجعة</h2></div>
        @if (Model.ShowRequestId)
        {
            <div class="erp-detail-item">
                <span>رقم الطلب</span>
                <strong><code>@Model.RequestId</code></strong>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا يوجد رقم طلب متاح لهذه العملية.</div>
        }
    </section>
</div>
