@model IEnumerable<MaterialManagement.BLL.ModelVM.Equipment.EquipmentViewModel>

@{
    ViewData["Title"] = "تقرير المعدات";
    var equipment = Model ?? Enumerable.Empty<MaterialManagement.BLL.ModelVM.Equipment.EquipmentViewModel>();
    var totalEquipment = equipment.Count();
    var withMaintenance = equipment.Count(e => e.LastMaintenanceDate.HasValue);
    var dueMaintenance = equipment.Count(e => e.NextMaintenanceDate.HasValue && e.NextMaintenanceDate.Value.Date <= DateTime.Today);
}

<div class="erp-page erp-report-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">التقارير</p>
            <h1>تقرير المعدات</h1>
            <p class="erp-table-note">ملخص عملي لحالة المعدات ومواعيد الصيانة.</p>
        </div>
        <div class="erp-actions no-print">
            <button type="button" class="btn btn-outline-primary" onclick="window.print()">طباعة</button>
            <a asp-action="Index" class="btn btn-outline-secondary">العودة للمعدات</a>
        </div>
    </div>

    <div class="erp-summary-strip erp-report-summary-strip">
        <div class="erp-summary-item"><span>إجمالي المعدات</span><strong>@totalEquipment</strong></div>
        <div class="erp-summary-item"><span>لها سجل صيانة</span><strong>@withMaintenance</strong></div>
        <div class="erp-summary-item"><span>صيانة مستحقة</span><strong>@dueMaintenance</strong></div>
        <div class="erp-summary-item"><span>تاريخ التقرير</span><strong>@DateTime.Today.ToString("yyyy-MM-dd")</strong></div>
    </div>

    <section class="erp-panel">
        <div class="erp-panel-header">
            <h2>قائمة تفصيلية بجميع المعدات</h2>
        </div>

        @if (equipment.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover erp-data-table erp-report-table">
                    <thead>
                        <tr>
                            <th>الكود</th>
                            <th>الاسم</th>
                            <th>تاريخ الشراء</th>
                            <th>آخر صيانة</th>
                            <th>الصيانة القادمة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in equipment.OrderBy(e => e.Code))
                        {
                            <tr>
                                <td class="erp-number">@item.Code</td>
                                <td>@item.Name</td>
                                <td>@item.PurchaseDate.ToString("yyyy-MM-dd")</td>
                                <td>@(item.LastMaintenanceDate?.ToString("yyyy-MM-dd") ?? "---")</td>
                                <td>@(item.NextMaintenanceDate?.ToString("yyyy-MM-dd") ?? "---")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا توجد بيانات معدات لعرضها في التقرير.</div>
        }
    </section>
</div>
