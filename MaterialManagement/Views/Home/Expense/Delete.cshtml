@model MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel

@{
    ViewData["Title"] = "حذف مصروف";
}

<div class="erp-page erp-confirm-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>حذف المصروف يتم من شاشة الحذف المعتمدة</h1>
            <p class="erp-table-note">الحذف يحتاج اعتماد المشرف في وحدة المصاريف الرئيسية.</p>
        </div>
    </div>

    <section class="erp-panel erp-danger-zone">
        <div class="erp-detail-grid mb-3">
            <div class="erp-detail-item"><span>الوصف</span><strong>@Model.Description</strong></div>
            <div class="erp-detail-item"><span>المبلغ</span><strong>@Model.Amount.ToString("N2")</strong></div>
        </div>
        <a asp-controller="Expense" asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">فتح تأكيد الحذف</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
    </section>
</div>
