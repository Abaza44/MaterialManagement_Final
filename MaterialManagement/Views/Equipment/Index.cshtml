@{
    ViewData["Title"] = "إدارة المعدات";
}

<div class="erp-page erp-list-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success erp-alert">@TempData["Success"]</div>
    }

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأصول والتشغيل</p>
            <h1>@ViewData["Title"]</h1>
            <p class="erp-table-note">تابع المعدات ومواعيد الصيانة وآخر حركة تشغيلية.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Report" class="btn btn-outline-primary"><i class="bi bi-file-earmark-text"></i> تقرير المعدات</a>
            <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> إضافة معدة جديدة</a>
        </div>
    </div>

    <section class="erp-panel erp-worksheet-panel">
        <div class="erp-panel-header">
            <div>
                <h2>قائمة المعدات</h2>
                <p class="erp-table-note">ابحث بالكود أو اسم المعدة، وافتح التفاصيل لمراجعة سجل الصيانة.</p>
            </div>
        </div>

        <div class="table-responsive">
            <table id="equipmentTable" class="table table-hover align-middle erp-data-table erp-worksheet-table" style="width:100%">
                <thead>
                    <tr>
                        <th>الكود</th>
                        <th>الاسم</th>
                        <th>تاريخ الشراء</th>
                        <th>آخر صيانة</th>
                        <th class="text-center">الإجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#equipmentTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/Equipment/LoadData",
                    "type": "POST"
                },
                "columns": [
                    { "data": "code", "className": "erp-number" },
                    { "data": "name" },
                    {
                        "data": "purchaseDate",
                        "render": function(data) {
                            return data ? new Date(data).toLocaleDateString('ar-EG-u-nu-latn', { year: 'numeric', month: 'long', day: 'numeric' }) : '---';
                        }
                    },
                    {
                        "data": "lastMaintenanceDate",
                        "render": function(data) {
                            return data ? new Date(data).toLocaleDateString('ar-EG-u-nu-latn', { year: 'numeric', month: 'long', day: 'numeric' }) : 'لا يوجد';
                        }
                    },
                    {
                        "data": "code",
                        "render": function (data) {
                            return `<div class="erp-table-actions">
                                        <a href="/Equipment/Details/${data}" class="btn btn-outline-primary btn-sm">تفاصيل</a>
                                        <a href="/Equipment/Edit/${data}" class="btn btn-outline-warning btn-sm">تعديل</a>
                                        <a href="/Equipment/Delete/${data}" class="btn btn-outline-danger btn-sm">حذف</a>
                                    </div>`;
                        },
                        "orderable": false,
                        "searchable": false
                    }
                ],
                "language": window.erpDataTablesArabic
            });
        });
    </script>
}
