@model MaterialManagement.BLL.ModelVM.Invoice.SalesInvoiceCreateModel

@using MaterialManagement.DAL.Enums

@{
    ViewData["Title"] = "إنشاء فاتورة بيع";
    var useMediatR = Context.Request.Query.ContainsKey("useMediatR") && Context.Request.Query["useMediatR"] == "true";
    var actionName = useMediatR ? "CreateMediatR" : "Create";
    var isWalkInCustomer = Model.PartyMode == SalesInvoicePartyMode.WalkInCustomer;
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice.css" asp-append-version="true" />
}

<div class="invoice-workbench" dir="rtl">
    <div class="invoice-toolbar no-print">
        <div>
            <p class="invoice-eyebrow">فواتير البيع</p>
            <h1>إنشاء فاتورة بيع</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">العودة للفواتير</a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger no-print">@TempData["ErrorMessage"]</div>
    }

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success no-print">@TempData["SuccessMessage"]</div>
    }

    <form asp-action="@actionName" method="post" id="invoiceEditorForm" class="invoice-editor">
        @Html.AntiForgeryToken()

        @if (useMediatR)
        {
            <div class="alert alert-info no-print">
                <strong>وضع الاختبار الداخلي نشط:</strong>
                يتم إرسال الفاتورة عبر مسار MediatR الموازي، بدون تغيير مسار الإنتاج الافتراضي.
            </div>
            <input type="hidden" name="useMediatR" value="true" />
        }

        <section class="invoice-section invoice-header-grid" aria-label="بيانات الفاتورة">
            <div class="invoice-field">
                <label asp-for="InvoiceNumber" class="form-label">رقم الفاتورة</label>
                <input asp-for="InvoiceNumber" class="form-control" placeholder="يتم توليده عند الحفظ" readonly />
                <span asp-validation-for="InvoiceNumber" class="text-danger"></span>
            </div>

            <div class="invoice-field">
                <label asp-for="InvoiceDate" class="form-label">تاريخ الفاتورة</label>
                <input asp-for="InvoiceDate" type="date" class="form-control" />
                <span asp-validation-for="InvoiceDate" class="text-danger"></span>
            </div>

            <div class="invoice-field">
                <label asp-for="PartyMode" class="form-label">نوع العميل</label>
                <select asp-for="PartyMode" class="form-select" data-sales-party-mode>
                    <option value="@SalesInvoicePartyMode.RegisteredClient">عميل مسجل</option>
                    <option value="@SalesInvoicePartyMode.WalkInCustomer">عميل نقدي / بدون تسجيل</option>
                </select>
                <span asp-validation-for="PartyMode" class="text-danger"></span>
            </div>

            <div class="invoice-field invoice-field-wide" data-sales-registered-client-field hidden="@(isWalkInCustomer ? "hidden" : null)">
                <label asp-for="ClientId" class="form-label">العميل</label>
                <select asp-for="ClientId" class="form-select" asp-items="@(new SelectList(ViewBag.Clients, "Id", "Name"))" disabled="@(isWalkInCustomer ? "disabled" : null)">
                    <option value="">اختر العميل</option>
                </select>
                <span asp-validation-for="ClientId" class="text-danger"></span>
            </div>

            <div class="invoice-field invoice-field-wide" data-sales-walk-in-field hidden="@(isWalkInCustomer ? null : "hidden")">
                <label asp-for="OneTimeCustomerName" class="form-label">اسم العميل النقدي</label>
                <input asp-for="OneTimeCustomerName" class="form-control" placeholder="مثال: عميل نقدي" disabled="@(isWalkInCustomer ? null : "disabled")" />
                <span asp-validation-for="OneTimeCustomerName" class="text-danger"></span>
            </div>

            <div class="invoice-field" data-sales-walk-in-field hidden="@(isWalkInCustomer ? null : "hidden")">
                <label asp-for="OneTimeCustomerPhone" class="form-label">هاتف اختياري</label>
                <input asp-for="OneTimeCustomerPhone" class="form-control" placeholder="اختياري" disabled="@(isWalkInCustomer ? null : "disabled")" />
                <span asp-validation-for="OneTimeCustomerPhone" class="text-danger"></span>
            </div>
        </section>

        <section class="invoice-section invoice-grid-section" aria-label="بنود الفاتورة">
            <div class="invoice-section-heading no-print">
                <div>
                    <h2>بنود الفاتورة</h2>
                    <p>استخدم Enter للتنقل السريع بين الخانات، و Alt+N لإضافة بند جديد.</p>
                </div>
                <button type="button" class="btn btn-primary" data-invoice-add-row>إضافة بند</button>
            </div>

            <div class="invoice-grid-wrap">
                <table class="invoice-entry-grid" id="itemsTable">
                    <thead>
                        <tr>
                            <th class="invoice-row-index">#</th>
                            <th>كود/باركود</th>
                            <th>المادة</th>
                            <th>المتاح</th>
                            <th>الكمية</th>
                            <th>سعر الوحدة</th>
                            <th>إجمالي البند</th>
                            <th class="no-print">حذف</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 0; i < Model.Items.Count; i++)
                        {
                            <tr data-invoice-row>
                                <td class="invoice-row-index" data-row-number>@(i + 1)</td>
                                <td>
                                    <input type="text" class="form-control invoice-cell" data-material-code placeholder="امسح أو اكتب الكود" autocomplete="off" />
                                </td>
                                <td>
                                    <select name="Items[@i].MaterialId" class="form-select invoice-cell" data-material-select>
                                        <option value="">اختر مادة</option>
                                        @foreach (var material in ViewBag.Materials)
                                        {
                                            <option value="@material.Id"
                                                    data-code="@material.Code"
                                                    data-price="@System.Convert.ToString(material.SellingPrice, System.Globalization.CultureInfo.InvariantCulture)"
                                                    data-stock="@System.Convert.ToString(material.AvailableQuantity, System.Globalization.CultureInfo.InvariantCulture)"
                                                    selected="@(Model.Items[i].MaterialId == material.Id ? "selected" : null)">
                                                @material.Code - @material.Name
                                            </option>
                                        }
                                    </select>
                                    <span asp-validation-for="@Model.Items[i].MaterialId" class="text-danger"></span>
                                </td>
                                <td class="invoice-stock-cell" data-stock-display>0.00</td>
                                <td>
                                    <input name="Items[@i].Quantity"
                                           value="@Model.Items[i].Quantity.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                           type="number"
                                           step="any"
                                           min="0"
                                           class="form-control invoice-cell invoice-number-input"
                                           data-quantity />
                                    <span asp-validation-for="@Model.Items[i].Quantity" class="text-danger"></span>
                                </td>
                                <td>
                                    <input name="Items[@i].UnitPrice"
                                           value="@Model.Items[i].UnitPrice.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                           type="number"
                                           step="0.01"
                                           min="0"
                                           class="form-control invoice-cell invoice-number-input"
                                           data-unit-price />
                                    <span asp-validation-for="@Model.Items[i].UnitPrice" class="text-danger"></span>
                                </td>
                                <td>
                                    <input type="text" class="form-control invoice-line-total" data-line-total value="0.00" readonly tabindex="-1" />
                                </td>
                                <td class="text-center no-print">
                                    <button type="button" class="btn btn-outline-danger btn-sm" data-invoice-remove-row>حذف</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <section class="invoice-section invoice-notes-section">
            <label asp-for="Notes" class="form-label">ملاحظات</label>
            <textarea asp-for="Notes" class="form-control" rows="2" placeholder="ملاحظات تظهر مع الفاتورة عند الحاجة"></textarea>
        </section>

        <div class="invoice-totals-bar no-print" aria-label="ملخص الفاتورة">
            <div class="invoice-total-box">
                <span>الإجمالي</span>
                <strong data-grand-total>0.00</strong>
            </div>

            <div class="invoice-total-input">
                <label asp-for="DiscountAmount">الخصم</label>
                <input asp-for="DiscountAmount" id="discountAmount" type="number" step="0.01" min="0" class="form-control invoice-number-input" value="@Model.DiscountAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-discount />
                <span asp-validation-for="DiscountAmount" class="text-danger"></span>
            </div>

            <div class="invoice-total-box">
                <span>الصافي</span>
                <strong data-net-total>0.00</strong>
            </div>

            <div class="invoice-total-input">
                <label asp-for="PaidAmount">المدفوع</label>
                <input asp-for="PaidAmount" id="paidAmount" type="number" step="0.01" min="0" class="form-control invoice-number-input" value="@Model.PaidAmount.ToString(System.Globalization.CultureInfo.InvariantCulture)" data-paid />
                <span asp-validation-for="PaidAmount" class="text-danger"></span>
            </div>

            <div class="invoice-total-box invoice-total-due">
                <span>المتبقي</span>
                <strong data-remaining-total>0.00</strong>
            </div>

            <button type="submit" class="btn btn-success invoice-save-button">حفظ الفاتورة</button>
        </div>
    </form>
</div>

<template id="invoiceRowTemplate">
    <tr data-invoice-row>
        <td class="invoice-row-index" data-row-number></td>
        <td>
            <input type="text" class="form-control invoice-cell" data-material-code placeholder="امسح أو اكتب الكود" autocomplete="off" />
        </td>
        <td>
            <select name="Items[__index__].MaterialId" class="form-select invoice-cell" data-material-select>
                <option value="">اختر مادة</option>
                @foreach (var material in ViewBag.Materials)
                {
                    <option value="@material.Id"
                            data-code="@material.Code"
                            data-price="@System.Convert.ToString(material.SellingPrice, System.Globalization.CultureInfo.InvariantCulture)"
                            data-stock="@System.Convert.ToString(material.AvailableQuantity, System.Globalization.CultureInfo.InvariantCulture)">
                        @material.Code - @material.Name
                    </option>
                }
            </select>
        </td>
        <td class="invoice-stock-cell" data-stock-display>0.00</td>
        <td>
            <input name="Items[__index__].Quantity" type="number" step="any" min="0" class="form-control invoice-cell invoice-number-input" data-quantity />
        </td>
        <td>
            <input name="Items[__index__].UnitPrice" type="number" step="0.01" min="0" class="form-control invoice-cell invoice-number-input" data-unit-price />
        </td>
        <td>
            <input type="text" class="form-control invoice-line-total" data-line-total value="0.00" readonly tabindex="-1" />
        </td>
        <td class="text-center no-print">
            <button type="button" class="btn btn-outline-danger btn-sm" data-invoice-remove-row>حذف</button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/invoice-editor.js" asp-append-version="true"></script>
}