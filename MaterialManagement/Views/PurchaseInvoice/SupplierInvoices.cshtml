@model MaterialManagement.BLL.ModelVM.Supplier.SupplierViewModel

@{
    ViewData["Title"] = $"فواتير الطرف: {Model.Name}";
}

<div class="erp-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">فواتير الشراء</p>
            <h1>فواتير الطرف: @Model.Name</h1>
            <p class="erp-table-note">يعرض الجدول عمليات الشراء النشطة مع إجماليات الرصيد والمتبقي.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">العودة للتجميع</a>
            <a asp-action="Create" class="btn btn-primary">فاتورة شراء جديدة</a>
        </div>
    </div>
    @if (Model.Id != 0)
    {
        <section class="erp-summary-strip mb-3">
            <div class="erp-summary-item">
                <span>رقم الهاتف</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Phone) ? "غير متوفر" : Model.Phone)</strong>
            </div>
            <div class="erp-summary-item">
                <span>العنوان</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.Address) ? "غير متوفر" : Model.Address)</strong>
            </div>
        </section>
    }

    <section class="erp-summary-strip mb-3">
        <div class="erp-summary-item">
            <span>رصيد سابق / مرحل</span>
            <strong id="openingBalance" class="erp-number">0.00</strong>
        </div>
        <div class="erp-summary-item">
            <span>إجمالي المتبقي من الفواتير</span>
            <strong id="grandTotalRemaining" class="erp-number text-danger">0.00</strong>
        </div>
        <div class="erp-summary-item">
            <span>الرصيد الإجمالي النهائي</span>
            <strong id="finalBalance" class="erp-number text-primary">0.00</strong>
        </div>
    </section>

<section class="erp-panel">
        <table id="invoicesTable" class="table table-bordered table-hover erp-data-table erp-report-table" style="width:100%">
            <thead>
                <tr>
                    <th>رقم الفاتورة</th>
                    <th>التاريخ</th>
                    <th>الإجمالي</th>
                    <th>المدفوع</th>
                    <th>المتبقي</th>
                    <th class="text-center">إجراءات</th>
                </tr>
            </thead>
        </table>
</section>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            const currencyFormat = $.fn.dataTable.render.number(',', '.', 2).display;

            $('#invoicesTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/PurchaseInvoice/LoadSupplierInvoices",
                    "type": "POST",
                    "data": function (d) {
                        d.supplierId = @Model.Id;
                    },
                    "dataSrc": function (json) {
                        // تحديث الإحصائيات في الـ tfoot
                        $('#openingBalance').text(json.openingBalance);
                        $('#grandTotalRemaining').text(json.grandTotalRemaining);
                        $('#finalBalance').text(json.finalBalance);

                        // فقط نرجع بيانات الفواتير
                        return json.data;
                    }
                },
                "columns": [
                    { "data": "invoiceNumber" },
                    { "data": "invoiceDate", "render": function(data) { return new Date(data).toLocaleDateString('ar-EG'); } },
                    { "data": "totalAmount", "render": currencyFormat, "className": "text-end erp-number" },
                    { "data": "paidAmount", "render": currencyFormat, "className": "text-end erp-number" },
                    {
                        "data": "remainingAmount",
                        "render": function(data) {
                            return data > 0 ? `<span class="badge bg-danger">${currencyFormat(data)}</span>` : `<span class="badge bg-success">مسدد</span>`;
                        },
                        "className": "text-end erp-number"
                    },
                    {
                        "data": "id",
                        "render": function (data) {
                            return `<div class='erp-table-actions'>` +
                                   `<a href='/PurchaseInvoice/Details/${data}' class='btn btn-outline-primary btn-sm'>التفاصيل</a>` +
                                   `<a href='/PurchaseInvoice/Delete/${data}' class='btn btn-outline-danger btn-sm'>حذف</a>` +
                                   `</div>`;
                        },
                        "orderable": false, "searchable": false
                    }
                ],
                "language": window.erpDataTablesArabic,
                "order": [[ 1, "desc" ]]
            });
        });
    </script>
}
