@model MaterialManagement.BLL.ModelVM.Reservation.ReservationDetailsViewModel
@using MaterialManagement.DAL.Entities
@using MaterialManagement.DAL.Enums
@{
    ViewData["Title"] = "تفاصيل الحجز";
    ViewData["SupervisorAuthorizationLabel"] = "اعتماد المشرف لإلغاء الحجز";
    ViewData["SupervisorAuthorizationHint"] = "إلغاء الحجز يحرر كميات محجوزة ويحتاج اعتماد المشرف قبل التنفيذ.";
}

<div class="erp-page">
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger erp-alert">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success erp-alert">@TempData["SuccessMessage"]</div>
    }

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الحجوزات</p>
            <h1>تفاصيل الحجز رقم: @Model.ReservationNumber</h1>
        </div>
        <div class="erp-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">العودة إلى القائمة</a>
        </div>
    </div>

    @if (Model.Status == ReservationStatus.Active)
    {
        <section class="erp-panel no-print">
            <div class="erp-panel-header">
                <div>
                    <h2>إجراءات الحجز</h2>
                    <p class="erp-table-note">استخدم التسليم لإنشاء فاتورة بيع بالكميات المطلوبة، أو عدل بيانات الحجز قبل أي تسليم.</p>
                </div>
            </div>
            <div class="erp-actions justify-content-start">
                <a asp-action="Fulfill" asp-route-id="@Model.Id" class="btn btn-success">
                    <i class="bi bi-truck"></i> تسليم جزئي / كلي
                </a>

                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-warning">
                    <i class="bi bi-pencil-square"></i> تعديل الحجز
                </a>
            </div>
        </section>
    }

    <section class="erp-panel">
        <div class="erp-panel-header">
            <h2>بيانات الحجز</h2>
        </div>

        <div class="erp-detail-grid mt-4">
            <div class="erp-detail-item">
                <span>@Html.DisplayNameFor(model => model.ClientName)</span>
                <strong>@Model.ClientName</strong>
            </div>
            <div class="erp-detail-item">
                <span>@Html.DisplayNameFor(model => model.ReservationDate)</span>
                <strong>@Model.ReservationDate.ToString("g")</strong>
            </div>
            <div class="erp-detail-item">
                <span>@Html.DisplayNameFor(model => model.Status)</span>
                <strong>@Model.Status</strong>
            </div>
            <div class="erp-detail-item">
                <span>@Html.DisplayNameFor(model => model.TotalAmount)</span>
                <strong>@Model.TotalAmount.ToString("C")</strong>
            </div>
        </div>

        <hr />
        <h4>الأصناف المحجوزة</h4>

        <table class="table table-hover align-middle erp-data-table">
            <thead>
                <tr>
                    <th>المادة</th>
                    <th>الكمية المحجوزة</th>
                    <th>تم تسليمه</th>
                    <th class="text-danger">المتبقي</th>
                    <th>سعر الوحدة</th>
                    <th>الإجمالي</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    var fulfilled = item.FulfilledQuantity ?? 0;
                    var remaining = item.Quantity - fulfilled;

                    <tr class="@(remaining == 0 ? "table-success text-muted" : "")">
                        <td>@item.MaterialName</td>
                        <td>@item.Quantity</td>
                        <td>@fulfilled</td>
                        <td class="fw-bold @(remaining > 0 ? "text-danger" : "")">@remaining</td>
                        <td>@item.UnitPrice.ToString("C")</td>
                        <td>@item.TotalPrice.ToString("C")</td>
                    </tr>
                }
            </tbody>
        </table>

    </section>

    @if (Model.Status == ReservationStatus.Active)
    {
        <section class="erp-panel erp-danger-zone no-print">
            <div class="erp-panel-header">
                <div>
                    <h2>إلغاء الحجز</h2>
                    <p class="erp-table-note">إلغاء الحجز يحرر الكميات المحجوزة، لذلك يحتاج اعتماد المشرف.</p>
                </div>
            </div>
            <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('هل أنت متأكد من إلغاء هذا الحجز؟')">
                @Html.AntiForgeryToken()
                <partial name="_SupervisorPasswordField" />
                <div class="erp-form-actions">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-x-circle"></i> إلغاء الحجز</button>
                </div>
            </form>
        </section>
    }
</div>
