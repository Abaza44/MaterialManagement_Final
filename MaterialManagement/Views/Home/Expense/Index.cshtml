@{
    ViewData["Title"] = "المصاريف";
}

<div class="erp-page erp-review-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>تم نقل شاشة المصاريف</h1>
            <p class="erp-table-note">استخدم شاشة المصاريف الرئيسية لإدارة القيود والتقارير. تم إبقاء هذه الصفحة كمسار احتياطي فقط.</p>
        </div>
    </div>

    <section class="erp-panel">
        <div class="erp-actions justify-content-start">
            <a asp-controller="Expense" asp-action="Index" class="btn btn-primary">فتح المصاريف</a>
            <a asp-controller="Expense" asp-action="Create" class="btn btn-outline-success">إضافة مصروف</a>
            <a asp-controller="Expense" asp-action="Report" class="btn btn-outline-primary">تقرير المصاريف</a>
        </div>
    </section>
</div>
