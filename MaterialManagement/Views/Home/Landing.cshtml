@{
    ViewData["Title"] = "الصفحة الرئيسية";
}

<div class="erp-page">

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">نظام إدارة المواد</p>
            <h1>مساحة التشغيل اليومية</h1>
            <p class="erp-table-note">إدارة المخزون، الفواتير، الحسابات، والحجوزات من نفس الواجهة.</p>
        </div>
        <div class="erp-actions">
            <a class="btn btn-lg btn-primary" asp-controller="Home" asp-action="Index">دخول إلى لوحة التحكم</a>
        </div>
    </div>

    <div class="erp-workflow-grid">
        <!-- المخزون -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>إدارة المخزون</h3>
                    <p>تسجيل ومتابعة حركة المواد والمخزون.</p>
                    <a asp-controller="Material" asp-action="Index" class="btn btn-outline-primary stretched-link">إدارة المواد</a>
                </div>
            </div>
        </div>

        <!-- الأطراف -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>العملاء والموردين</h3>
                    <p>إدارة حسابات وأرصدة العملاء والموردين.</p>
                    <a asp-controller="Client" asp-action="Index" class="btn btn-outline-secondary">العملاء</a>
                    <a asp-controller="Supplier" asp-action="Index" class="btn btn-outline-secondary ms-2">الموردين</a>
                </div>
            </div>
        </div>

        <!-- الفواتير -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>الفواتير</h3>
                    <p>إنشاء وتتبع فواتير البيع والشراء.</p>
                    <a asp-controller="SalesInvoice" asp-action="Index" class="btn btn-outline-success">فواتير البيع</a>
                    <a asp-controller="PurchaseInvoice" asp-action="Index" class="btn btn-outline-success ms-2">فواتير الشراء</a>
                </div>
            </div>
        </div>

        <!-- المالية -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>المالية</h3>
                    <p>تسجيل التحصيلات والدفعات والمصاريف اليومية.</p>
                    <a asp-controller="Payment" asp-action="AddClientPayment" class="btn btn-outline-info">إضافة تحصيل</a>
                    <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-info ms-2">المصاريف</a>
                </div>
            </div>
        </div>

        <!-- العمليات -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>العمليات والصيانة</h3>
                    <p>إدارة أصول الشركة وتسجيل عمليات الصيانة.</p>
                    <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-dark">المعدات</a>
                    <a asp-controller="Maintenance" asp-action="Index" class="btn btn-outline-dark ms-2">سجلات الصيانة</a>
                </div>
            </div>
        </div>

        <!-- التقارير -->
        <div>
            <div class="card h-100">
                <div class="card-body">
                    <h3>التقارير</h3>
                    <p>تقارير مالية ومخزنية لمتابعة الأداء.</p>
                    <a asp-controller="Report" asp-action="AccountStatement" class="btn btn-outline-danger stretched-link">
                عرض التقارير
            </a>
                </div>
            </div>
        </div>
    </div>

</div>
