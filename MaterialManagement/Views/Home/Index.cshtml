@{
    ViewData["Title"] = "لوحة التحكم";
    var culture = new System.Globalization.CultureInfo("ar-EG");
    decimal totalSales = (decimal)(ViewBag.TotalSalesMonth ?? 0m);
    decimal totalPurchases = (decimal)(ViewBag.TotalPurchasesMonth ?? 0m);
    decimal totalExpenses = (decimal)(ViewBag.TotalExpensesMonth ?? 0m);
    decimal totalClientDebt = (decimal)(ViewBag.TotalClientDebt ?? 0m);
    decimal totalSupplierDebt = (decimal)(ViewBag.TotalSupplierDebt ?? 0m);
    decimal netFlow = totalSales - (totalPurchases + totalExpenses);
}

<div class="erp-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">لوحة التشغيل</p>
            <h1>لوحة التحكم</h1>
        </div>
        <span class="erp-status-pill">@DateTime.Now.ToString("dddd، dd MMMM yyyy", culture)</span>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger erp-alert">@TempData["ErrorMessage"]</div>
    }

    <section class="erp-dashboard-grid mb-3" aria-label="ملخص مالي للشهر الحالي">
        <div class="erp-metric-card erp-metric-card-success">
            <i class="bi bi-receipt"></i>
            <span>مبيعات الشهر</span>
            <strong>@totalSales.ToString("C", culture)</strong>
            <small>إجمالي فواتير البيع المسجلة خلال الشهر الحالي.</small>
        </div>

        <div class="erp-metric-card">
            <i class="bi bi-bag-check"></i>
            <span>مشتريات الشهر</span>
            <strong>@totalPurchases.ToString("C", culture)</strong>
            <small>إجمالي فواتير الشراء المسجلة خلال الشهر الحالي.</small>
        </div>

        <div class="erp-metric-card">
            <i class="bi bi-cash-stack"></i>
            <span>مصروفات الشهر</span>
            <strong>@totalExpenses.ToString("C", culture)</strong>
            <small>إجمالي المصروفات التشغيلية خلال الشهر الحالي.</small>
        </div>

        <div class="erp-metric-card @(netFlow >= 0 ? "erp-metric-card-success" : "erp-metric-card-danger")">
            <i class="bi bi-activity"></i>
            <span>صافي التدفق التقريبي</span>
            <strong>@netFlow.ToString("C", culture)</strong>
            <small>المبيعات ناقص المشتريات والمصروفات.</small>
        </div>
    </section>

    <section class="erp-panel">
        <div class="erp-panel-header">
            <div>
                <h2>نظرة عامة على الأداء</h2>
                <p class="erp-table-note">قراءة سريعة للشهر الحالي قبل الدخول إلى التقارير التفصيلية.</p>
            </div>
        </div>
        <canvas id="financeChart" height="100"></canvas>
    </section>

    <section class="erp-summary-strip mb-3" aria-label="ملخص الأرصدة والعمليات">
        <a asp-controller="Material" asp-action="LowStock" class="erp-summary-item text-decoration-none">
            <span>تنبيهات نقص المخزون</span>
            <strong>@(ViewBag.LowStockCount ?? 0)</strong>
        </a>

        <a asp-controller="Client" asp-action="Index" class="erp-summary-item text-decoration-none">
            <span>ديون العملاء</span>
            <strong>@totalClientDebt.ToString("C", culture)</strong>
        </a>

        <a asp-controller="Supplier" asp-action="Index" class="erp-summary-item text-decoration-none">
            <span>مستحقات الموردين</span>
            <strong>@totalSupplierDebt.ToString("C", culture)</strong>
        </a>

        <a asp-controller="Employee" asp-action="Index" class="erp-summary-item text-decoration-none">
            <span>الموظفون النشطون</span>
            <strong>@(ViewBag.TotalEmployees ?? 0)</strong>
        </a>
    </section>

    <section class="erp-workflow-grid" aria-label="الوصول السريع">
        <a asp-controller="SalesInvoice" asp-action="Create" class="erp-action-card">
            <i class="bi bi-plus-circle"></i>
            <strong>فاتورة بيع</strong>
            <span>إدخال بنود البيع وحساب الخصم والمدفوع والمتبقي.</span>
        </a>

        <a asp-controller="PurchaseInvoice" asp-action="Create" class="erp-action-card">
            <i class="bi bi-bag-plus"></i>
            <strong>فاتورة شراء</strong>
            <span>تسجيل شراء من مورد أو مرتجع عميل حسب نوع العملية.</span>
        </a>

        <a asp-controller="Payment" asp-action="AddClientPayment" class="erp-action-card">
            <i class="bi bi-wallet2"></i>
            <strong>تحصيل عميل</strong>
            <span>إضافة دفعة مرتبطة بفاتورة أو دفعة غير مخصصة ضمن الرصيد المستحق.</span>
        </a>

        <a asp-controller="Expense" asp-action="Create" class="erp-action-card">
            <i class="bi bi-cash"></i>
            <strong>مصروف جديد</strong>
            <span>تسجيل مصروف تشغيلي وربطه بتصنيف وطريقة دفع.</span>
        </a>

        <a asp-controller="Reservation" asp-action="Create" class="erp-action-card">
            <i class="bi bi-calendar-check"></i>
            <strong>حجز مخزون</strong>
            <span>حجز كميات للعميل بدون تغيير رصيد الحساب حتى التسليم.</span>
        </a>

        <a asp-controller="Report" asp-action="AccountStatement" class="erp-action-card">
            <i class="bi bi-person-lines-fill"></i>
            <strong>كشف حساب</strong>
            <span>مراجعة حركة عميل أو مورد مع الرصيد النهائي.</span>
        </a>
    </section>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('financeChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['المبيعات', 'المشتريات', 'المصاريف', 'صافي التدفق'],
                datasets: [{
                    label: 'القيمة بالجنيه المصري',
                    data: [
                        @totalSales,
                        @totalPurchases,
                        @totalExpenses,
                        @netFlow
                    ],
                    backgroundColor: ['#28a745', '#17a2b8', '#ffc107', '#007bff']
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { display: false },
                    tooltip: { rtl: true }
                },
                scales: {
                    y: { beginAtZero: true }
                }
            }
        });
    </script>
}
