@model MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel

@{
    ViewData["Title"] = "تفاصيل مصروف";
}

<div class="erp-page erp-review-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>تفاصيل المصروف انتقلت إلى وحدة المصاريف</h1>
            <p class="erp-table-note">@Model.Description</p>
        </div>
    </div>

    <section class="erp-panel">
        <div class="erp-detail-grid mb-3">
            <div class="erp-detail-item"><span>الوصف</span><strong>@Model.Description</strong></div>
            <div class="erp-detail-item"><span>المبلغ</span><strong>@Model.Amount.ToString("N2")</strong></div>
        </div>
        <a asp-controller="Expense" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary">فتح التفاصيل المعتمدة</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
    </section>
</div>
