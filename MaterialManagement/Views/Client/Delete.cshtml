@model MaterialManagement.BLL.ModelVM.Client.ClientViewModel

@{
    ViewData["Title"] = "حذف عميل";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="erp-page erp-narrow-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">العملاء</p>
            <h1 class="text-danger">حذف عميل</h1>
        </div>
    </div>

    <div class="erp-panel erp-danger-zone">
        <div class="erp-panel-header"><h2>تأكيد الحذف</h2></div>
        <p class="mb-3">هل أنت متأكد أنك تريد حذف العميل <strong>@Model.Name</strong>؟</p>

        <div class="erp-detail-grid mb-3">
            <div class="erp-detail-item"><span>الهاتف</span><strong>@(Model.Phone ?? "-")</strong></div>
            <div class="erp-detail-item"><span>الرصيد</span><strong>@Model.Balance.ToString("N2")</strong></div>
        </div>

        <form asp-action="Delete" method="post" class="erp-form-actions">
            <input type="hidden" asp-for="Id" />
            <partial name="_SupervisorPasswordField" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> حذف</button>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
        </form>
    </div>
</div>
