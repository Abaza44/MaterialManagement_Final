@model MaterialManagement.BLL.ModelVM.Material.MaterialCreateModel

@{
    ViewData["Title"] = "إضافة مادة جديدة";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">المخزون</p>
            <h1>إضافة مادة جديدة</h1>
        </div>
    </div>

    <form asp-action="Create" method="post" class="erp-panel">
        <div class="erp-form-grid">
            <div>
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Code" class="form-label"></label>
                <input asp-for="Code" class="form-control" />
                <span asp-validation-for="Code" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Unit" class="form-label"></label>
                <input asp-for="Unit" class="form-control" />
                <span asp-validation-for="Unit" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="MinimumQuantity" class="form-label"></label>
                <input asp-for="MinimumQuantity" class="form-control" type="number" step="any" placeholder="الكمية التي سيظهر عندها تنبيه" />
                <span asp-validation-for="MinimumQuantity" class="text-danger"></span>
            </div>

            <div class="form-check align-self-end">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label">نشط</label>
            </div>

            <div class="erp-field-wide">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
        </div>

        <div class="erp-form-actions">
            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> حفظ</button>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
        </div>
    </form>
</div>
