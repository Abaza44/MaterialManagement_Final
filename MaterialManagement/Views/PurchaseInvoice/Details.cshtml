@model MaterialManagement.BLL.ModelVM.Invoice.PurchaseInvoiceDetailsViewModel
@using MaterialManagement.BLL.ModelVM.Invoice
@using MaterialManagement.BLL.ModelVM.Payment
@using MaterialManagement.DAL.Enums
@using System.Collections.Generic
@using System.Globalization
@using System.Linq

@{
    var invoice = Model.Invoice;
    ViewData["Title"] = $"تفاصيل العملية #{invoice.InvoiceNumber}";

    var culture = CultureInfo.GetCultureInfo("ar-EG");
    var items = invoice.Items ?? new List<PurchaseInvoiceItemViewModel>();
    var payments = Model.Payments ?? new List<SupplierPaymentViewModel>();
    var totalQuantity = items.Sum(i => i.Quantity);
    var grossTotal = items.Sum(i => i.TotalPrice);
    var discountAmount = Math.Max(grossTotal - invoice.TotalAmount, 0);
    var netTotal = invoice.TotalAmount;
    var totalPaymentsOnInvoice = payments.Sum(p => p.Amount);
    var isRegisteredSupplierPurchase = invoice.PartyMode == PurchaseInvoicePartyMode.RegisteredSupplier;
    var isOneTimeSupplierPurchase = invoice.PartyMode == PurchaseInvoicePartyMode.OneTimeSupplier;
    var isSupplierPurchase = isRegisteredSupplierPurchase || isOneTimeSupplierPurchase;
    var modeLabel = isOneTimeSupplierPurchase ? "شراء من مورد يدوي" : (isRegisteredSupplierPurchase ? "شراء من مورد" : "مرتجع من عميل");
    var partyLabel = isOneTimeSupplierPurchase ? "المورد اليدوي" : (isRegisteredSupplierPurchase ? "المورد" : "العميل");
    var partyName = isSupplierPurchase ? invoice.SupplierName : invoice.ClientName;
    var partyController = isRegisteredSupplierPurchase ? "Supplier" : "Client";
    var partyId = isRegisteredSupplierPurchase ? invoice.SupplierId : invoice.ClientId;
    var remainingStatusClass = invoice.RemainingAmount > 0 ? "invoice-status-due" : "invoice-status-paid";
    var remainingStatusText = invoice.RemainingAmount > 0 ? "مستحق" : "مسدد";
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice.css" asp-append-version="true" />
}

<div class="invoice-workbench invoice-document-workbench" dir="rtl">
    <div class="invoice-toolbar invoice-review-toolbar no-print">
        <div>
            <p class="invoice-eyebrow">مراجعة عملية شراء / مرتجع</p>
            <h1>@modeLabel @invoice.InvoiceNumber</h1>
        </div>

        <div class="invoice-toolbar-actions">
            <button type="button" class="btn btn-outline-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> طباعة
            </button>

            @if (isRegisteredSupplierPurchase && invoice.RemainingAmount > 0 && invoice.SupplierId.HasValue)
            {
                <a asp-controller="Payment"
                   asp-action="AddSupplierPayment"
                   asp-route-supplierId="@invoice.SupplierId"
                   asp-route-invoiceId="@invoice.Id"
                   class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> إضافة دفعة
                </a>
            }

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-list-ul"></i> العودة للقائمة
            </a>
        </div>
    </div>

    <article class="invoice-document" aria-label="تفاصيل عملية الشراء أو المرتجع">
        <header class="invoice-document-header">
            <div class="invoice-document-brand">
                <p class="invoice-eyebrow">@modeLabel</p>
                <h2>@invoice.InvoiceNumber</h2>
                <span>تاريخ العملية: @invoice.InvoiceDate.ToString("yyyy/MM/dd", culture)</span>
            </div>

            <div class="invoice-document-status @remainingStatusClass">
                <span>@remainingStatusText</span>
                <strong>@invoice.RemainingAmount.ToString("N2", culture)</strong>
                <small>ج.م متبقي</small>
            </div>
        </header>

        <section class="invoice-document-meta" aria-label="بيانات العملية">
            <div class="invoice-meta-item">
                <span>@partyLabel</span>
                <strong>
                    @if (partyId.HasValue)
                    {
                        <a asp-controller="@partyController"
                           asp-action="Details"
                           asp-route-id="@partyId"
                           class="invoice-document-link">
                            @partyName
                        </a>
                    }
                    else
                    {
                        <span>@(partyName ?? "غير محدد")</span>
                    }
                </strong>
                @if (isOneTimeSupplierPurchase && !string.IsNullOrWhiteSpace(invoice.OneTimeSupplierPhone))
                {
                    <small class="invoice-meta-note">@invoice.OneTimeSupplierPhone</small>
                }
            </div>

            <div class="invoice-meta-item">
                <span>نوع العملية</span>
                <strong>@modeLabel</strong>
            </div>

            <div class="invoice-meta-item">
                <span>إجمالي الكميات</span>
                <strong>@totalQuantity.ToString("N2", culture)</strong>
            </div>

            <div class="invoice-meta-item">
                <span>صافي العملية</span>
                <strong>@netTotal.ToString("N2", culture) ج.م</strong>
            </div>
        </section>

        <section class="invoice-document-lines" aria-label="بنود العملية">
            <div class="invoice-document-section-heading">
                <h3>بنود العملية</h3>
                <span>@items.Count.ToString("N0", culture) بند</span>
            </div>

            <div class="invoice-grid-wrap invoice-review-grid-wrap">
                <table class="invoice-entry-grid invoice-review-grid">
                    <thead>
                        <tr>
                            <th class="invoice-row-index">#</th>
                            <th>كود المادة</th>
                            <th>المادة</th>
                            <th class="invoice-number-column">الكمية</th>
                            <th class="invoice-number-column">سعر الوحدة</th>
                            <th class="invoice-number-column">إجمالي البند</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < items.Count; i++)
                        {
                            var item = items[i];
                            <tr>
                                <td class="invoice-row-index">@(i + 1)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.MaterialCode) ? "-" : item.MaterialCode)</td>
                                <td>@item.MaterialName</td>
                                <td class="invoice-number-column">@item.Quantity.ToString("N2", culture)</td>
                                <td class="invoice-number-column">@item.UnitPrice.ToString("N2", culture)</td>
                                <td class="invoice-number-column invoice-line-total-text">@item.TotalPrice.ToString("N2", culture)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">إجمالي البنود</td>
                            <td class="invoice-number-column">@totalQuantity.ToString("N2", culture)</td>
                            <td></td>
                            <td class="invoice-number-column">@grossTotal.ToString("N2", culture)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>

        <section class="invoice-review-bottom" aria-label="ملخص العملية">
            <div class="invoice-notes-panel">
                <h3>ملاحظات</h3>
                @if (!string.IsNullOrWhiteSpace(invoice.Notes))
                {
                    <p>@invoice.Notes</p>
                }
                else
                {
                    <p class="invoice-muted-text">لا توجد ملاحظات مسجلة على هذه العملية.</p>
                }
            </div>

            <aside class="invoice-summary-panel" aria-label="إجماليات العملية">
                <div class="invoice-summary-row">
                    <span>الإجمالي قبل الخصم</span>
                    <strong>@grossTotal.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row">
                    <span>الخصم</span>
                    <strong>@discountAmount.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row invoice-summary-row-total">
                    <span>الصافي</span>
                    <strong>@netTotal.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row">
                    <span>المسدد / المسترجع</span>
                    <strong>@invoice.PaidAmount.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row invoice-summary-row-due">
                    <span>المتبقي</span>
                    <strong>@invoice.RemainingAmount.ToString("N2", culture) ج.م</strong>
                </div>
            </aside>
        </section>

        @if (isRegisteredSupplierPurchase)
        {
            <section class="invoice-payment-history no-print" aria-label="سجل دفعات المورد">
                <div class="invoice-document-section-heading">
                    <h3>سجل دفعات المورد</h3>
                    @if (invoice.RemainingAmount > 0 && invoice.SupplierId.HasValue)
                    {
                        <a asp-controller="Payment"
                           asp-action="AddSupplierPayment"
                           asp-route-supplierId="@invoice.SupplierId"
                           asp-route-invoiceId="@invoice.Id"
                           class="btn btn-outline-primary btn-sm">
                            إضافة دفعة
                        </a>
                    }
                </div>

                @if (payments.Any())
                {
                    <div class="invoice-grid-wrap invoice-review-grid-wrap">
                        <table class="invoice-entry-grid invoice-review-grid invoice-payment-grid">
                            <thead>
                                <tr>
                                    <th>تاريخ الدفعة</th>
                                    <th class="invoice-number-column">المبلغ</th>
                                    <th>طريقة الدفع</th>
                                    <th>ملاحظات</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var payment in payments)
                                {
                                    <tr>
                                        <td>@payment.PaymentDate.ToString("yyyy/MM/dd", culture)</td>
                                        <td class="invoice-number-column">@payment.Amount.ToString("N2", culture)</td>
                                        <td>@payment.PaymentMethod</td>
                                        <td>@(payment.Notes ?? "-")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <td>إجمالي الدفعات المسجلة</td>
                                    <td class="invoice-number-column">@totalPaymentsOnInvoice.ToString("N2", culture)</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }
                else
                {
                    <p class="invoice-muted-text mb-0">لا توجد دفعات مسجلة لهذه الفاتورة بعد.</p>
                }
            </section>
        }
    </article>
</div>
