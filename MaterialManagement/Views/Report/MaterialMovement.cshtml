@{
    ViewData["Title"] = "تقرير حركة صنف";
}

<div class="erp-page erp-report-picker-page erp-report-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">التقارير</p>
            <h1>تقرير حركة صنف</h1>
        </div>
    </div>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger erp-alert">@TempData["Error"]</div>
}

<div class="erp-panel erp-report-filter-panel">
    <div class="erp-panel-header">
        <div>
            <h2>اختر المادة والفترة الزمنية</h2>
            <p class="erp-table-note">يعرض التقرير الوارد والصادر والرصيد المتدرج للصنف خلال الفترة المحددة.</p>
        </div>
    </div>
    <form asp-action="MaterialMovementResult" method="get">
        <div class="erp-form-grid">
            <div>
                <label class="form-label fw-bold">المادة</label>
                    <select name="materialId" class="form-select" asp-items="ViewBag.Materials" required>
                    <option value="">اختر مادة</option>
                    </select>
            </div>
            <div>
                <label class="form-label fw-bold">من تاريخ</label>
                <input type="date" name="fromDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
            <div>
                <label class="form-label fw-bold">إلى تاريخ</label>
                <input type="date" name="toDate" class="form-control" required value="@DateTime.Now.ToString("yyyy-MM-dd")" />
            </div>
        </div>
        <div class="erp-form-actions">
            <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> عرض حركة الصنف</button>
        </div>
    </form>
</div>
</div>
