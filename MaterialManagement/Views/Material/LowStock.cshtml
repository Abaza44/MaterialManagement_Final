@model IEnumerable<MaterialManagement.BLL.ModelVM.Material.MaterialViewModel>

@{
    ViewData["Title"] = "المواد منخفضة المخزون";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="erp-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">المخزون</p>
            <h1 class="text-warning">المواد منخفضة المخزون</h1>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">رجوع للمواد</a>
    </div>

    <div class="erp-panel">
        <table class="table table-hover erp-data-table">
            <thead>
                <tr>
                    <th>الكود</th>
                    <th>الاسم</th>
                    <th>الكمية</th>
                    <th>حالة المخزون</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Code</td>
                            <td>@item.Name</td>
                            <td class="erp-number">@item.Quantity.ToString("N2")</td>
                            <td><span class="badge bg-warning text-dark">@item.StockStatus</span></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center erp-muted">لا توجد مواد منخفضة المخزون الآن</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
