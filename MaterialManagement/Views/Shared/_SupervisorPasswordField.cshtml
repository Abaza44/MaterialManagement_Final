@{
    var label = ViewData["SupervisorAuthorizationLabel"] as string
        ?? "كلمة مرور / PIN المشرف";
    var hint = ViewData["SupervisorAuthorizationHint"] as string
        ?? "لن يتم تنفيذ هذا الإجراء قبل التحقق من كلمة مرور المشرف على الخادم.";
    var supervisorErrors = ViewData.ModelState["SupervisorPassword"]?.Errors;
    var supervisorError = supervisorErrors != null && supervisorErrors.Count > 0
        ? supervisorErrors[0].ErrorMessage
        : null;
}

<div class="mb-3">
    <label for="SupervisorPassword" class="form-label fw-bold">@label</label>
    <input id="SupervisorPassword"
           name="SupervisorPassword"
           type="password"
           class="form-control @(string.IsNullOrWhiteSpace(supervisorError) ? "" : "is-invalid")"
           autocomplete="current-password"
           inputmode="numeric"
           required />
    <div class="form-text">@hint</div>
    @if (!string.IsNullOrWhiteSpace(supervisorError))
    {
        <div class="invalid-feedback d-block">@supervisorError</div>
    }
</div>
