@{
    ViewData["Title"] = "إدارة العملاء";
}

<div class="erp-page erp-list-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأطراف</p>
            <h1>@ViewData["Title"]</h1>
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> إضافة عميل جديد
        </a>
    </div>

    <div class="erp-panel erp-filter-panel">
        <div class="erp-panel-header">
            <h2><i class="bi bi-funnel"></i> فلاتر</h2>
        </div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" value="" id="hasDebtFilter">
            <label class="form-check-label" for="hasDebtFilter">
                عرض العملاء أصحاب المديونيات فقط
            </label>
        </div>
    </div>

    <section class="erp-panel erp-worksheet-panel">
        <div class="table-responsive">
            <table id="clientsTable" class="table table-hover erp-data-table erp-worksheet-table" style="width:100%">
                <thead>
                    <tr>
                        <th>الاسم</th>
                        <th>الهاتف</th>
                        <th>الرصيد (المديونية)</th>
                        <th>الحالة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var clientsDataTable = $('#clientsTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/Client/LoadData",
                    "type": "POST",
                    "data": function (d) {
                        d.hasDebtFilter = $('#hasDebtFilter').is(':checked');
                    }
                },
                "columns": [
                    { "data": "name" },
                    { "data": "phone" },
                    {
                        "data": "balance",
                        "render": function(data) {
                            return data > 0 ? `<span class="text-danger fw-bold">${data.toFixed(2)}</span>` : data.toFixed(2);
                        }
                    },
                    {
                        "data": "isActive",
                        "render": function(data) {
                            return data ? '<span class="badge bg-success">نشط</span>' : '<span class="badge bg-danger">غير نشط</span>';
                        }
                    },
                    {
                        "data": "id",
                        "render": function (data, type, row) {
                            let buttons = `<a href='/Client/Details/${data}' class='btn btn-outline-primary btn-sm'>تفاصيل</a> ` +
                                          `<a href='/Client/Edit/${data}' class='btn btn-outline-warning btn-sm'>تعديل</a> ` +
                                          `<a href='/Client/Delete/${data}' class='btn btn-outline-danger btn-sm'>حذف</a>`;
                            if (!row.isActive) {
                                buttons += ` <a href='/Client/Reactivate/${data}' class='btn btn-success btn-sm'>تنشيط</a>`;
                            }
                            return buttons;
                        },
                        "orderable": false
                    }
                ],
                "language": window.erpDataTablesArabic
            });

            $('#hasDebtFilter').on('change', function() {
                clientsDataTable.draw();
            });
        });
    </script>
}
