@{
    ViewData["Title"] = "إدارة الموردين";
}

<div class="erp-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأطراف</p>
            <h1>@ViewData["Title"]</h1>
        </div>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> إضافة مورد جديد
        </a>
    </div>

    <div class="erp-panel erp-filter-panel">
        <div class="erp-panel-header"><h2><i class="bi bi-funnel"></i> فلاتر</h2></div>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" value="" id="hasCreditFilter">
            <label class="form-check-label" for="hasCreditFilter">
                عرض الموردين أصحاب المستحقات فقط
            </label>
        </div>
    </div>

    <table id="suppliersTable" class="table table-hover erp-data-table" style="width:100%">
        <thead>
            <tr>
                <th>الاسم</th>
                <th>الهاتف</th>
                <th>الرصيد (المستحقات)</th>
                <th>الحالة</th>
                <th>إجراءات</th>
            </tr>
        </thead>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var suppliersDataTable = $('#suppliersTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/Supplier/LoadData",
                    "type": "POST",
                    "data": function (d) {
                        d.hasCreditFilter = $('#hasCreditFilter').is(':checked');
                    }
                },
                "columns": [
                    { "data": "name" },
                    { "data": "phone" },
                    {
                        "data": "balance",
                        "render": function(data) {
                            return data > 0 ? `<span class="text-success fw-bold">${data.toFixed(2)}</span>` : data.toFixed(2);
                        }
                    },
                    {
                        "data": "isActive",
                        "render": function(data) {
                            return data ? '<span class="badge bg-success">نشط</span>' : '<span class="badge bg-danger">غير نشط</span>';
                        }
                    },
                    {
                        "data": "id",
                        "render": function (data, type, row) {
                            let buttons = `<a href='/Supplier/Details/${data}' class='btn btn-outline-primary btn-sm'>تفاصيل</a> ` +
                                          `<a href='/Supplier/Edit/${data}' class='btn btn-outline-warning btn-sm'>تعديل</a> ` +
                                          `<a href='/Supplier/Delete/${data}' class='btn btn-outline-danger btn-sm'>حذف</a>`;
                            if (!row.isActive) {
                                buttons += ` <a href='/Supplier/Reactivate/${data}' class='btn btn-success btn-sm'>تنشيط</a>`;
                            }
                            return buttons;
                        },
                        "orderable": false
                    }
                ],
                "language": window.erpDataTablesArabic
            });

            $('#hasCreditFilter').on('change', function() {
                suppliersDataTable.draw();
            });
        });
    </script>
}
