@model MaterialManagement.BLL.ModelVM.Employee.EmployeeUpdateModel

@{
    ViewData["Title"] = "تعديل بيانات موظف";
}

<div class="erp-page erp-narrow-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الموارد البشرية</p>
            <h1>تعديل بيانات الموظف</h1>
            <p class="erp-table-note">@Model.Name</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">العودة للموظفين</a>
    </div>

    <form asp-action="Edit" method="post" class="erp-panel">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="erp-form-grid">
            <div>
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" autocomplete="name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Phone" class="form-label fw-bold"></label>
                <input asp-for="Phone" class="form-control" autocomplete="tel" />
                <span asp-validation-for="Phone" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Position" class="form-label fw-bold"></label>
                <input asp-for="Position" class="form-control" />
                <span asp-validation-for="Position" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Salary" class="form-label fw-bold"></label>
                <input asp-for="Salary" class="form-control erp-number" type="number" step="0.01" min="0" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="HireDate" class="form-label fw-bold"></label>
                <input asp-for="HireDate" class="form-control" type="date" />
                <span asp-validation-for="HireDate" class="text-danger"></span>
            </div>

            <div class="form-check align-self-end">
                <input asp-for="IsActive" class="form-check-input" />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
        </div>

        <div class="erp-form-actions">
            <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> حفظ التعديلات</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
