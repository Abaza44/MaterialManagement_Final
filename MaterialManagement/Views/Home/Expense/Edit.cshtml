@model MaterialManagement.BLL.ModelVM.Expense.ExpenseUpdateModel

@{
    ViewData["Title"] = "تعديل مصروف";
}

<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>تعديل المصروف يتم من شاشة المصاريف الرئيسية</h1>
            <p class="erp-table-note">سيتم تحويل هذا المسار إلى نموذج التعديل المعتمد.</p>
        </div>
    </div>

    <section class="erp-panel">
        <a asp-controller="Expense" asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">فتح نموذج التعديل</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
    </section>
</div>
