@model IEnumerable<MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel>

@{
    ViewData["Title"] = "تقرير المصاريف";
}

<div class="erp-page erp-narrow-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>تقرير المصاريف انتقل إلى وحدة المصاريف</h1>
            <p class="erp-table-note">استخدم التقرير المعتمد للحصول على أرقام الشهر والفئات.</p>
        </div>
    </div>

    <section class="erp-panel">
        <a asp-controller="Expense" asp-action="Report" class="btn btn-primary">فتح تقرير المصاريف</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
    </section>
</div>
