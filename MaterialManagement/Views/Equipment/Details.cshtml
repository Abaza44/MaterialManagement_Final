@model MaterialManagement.BLL.ModelVM.Equipment.EquipmentViewModel

@{
    ViewData["Title"] = $"تفاصيل المعدة: {Model.Name}";
}

<div class="erp-page erp-list-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأصول والتشغيل</p>
            <h1>تفاصيل المعدة</h1>
            <p class="erp-table-note">@Model.Name - كود @Model.Code</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Edit" asp-route-code="@Model.Code" class="btn btn-outline-warning">تعديل</a>
            <a asp-controller="Maintenance" asp-action="AddForEquipment" asp-route-equipmentCode="@Model.Code" class="btn btn-primary">إضافة صيانة</a>
            <a asp-action="Index" class="btn btn-outline-secondary">العودة للمعدات</a>
        </div>
    </div>

    <section class="erp-panel erp-worksheet-panel">
        <div class="erp-panel-header">
            <h2>البيانات الأساسية</h2>
        </div>
        <div class="erp-detail-grid">
            <div class="erp-detail-item"><span>الكود</span><strong>@Model.Code</strong></div>
            <div class="erp-detail-item"><span>الاسم</span><strong>@Model.Name</strong></div>
            <div class="erp-detail-item"><span>تاريخ الشراء</span><strong>@Model.PurchaseDate.ToString("yyyy-MM-dd")</strong></div>
            <div class="erp-detail-item"><span>آخر صيانة</span><strong>@(Model.LastMaintenanceDate?.ToString("yyyy-MM-dd") ?? "لا يوجد")</strong></div>
            <div class="erp-detail-item"><span>الصيانة القادمة</span><strong>@(Model.NextMaintenanceDate?.ToString("yyyy-MM-dd") ?? "غير محددة")</strong></div>
        </div>
    </section>

    <section class="erp-panel">
        <div class="erp-panel-header">
            <div>
                <h2><i class="bi bi-clock-history"></i> سجل الصيانة</h2>
                <p class="erp-table-note">كل عمليات الصيانة المسجلة لهذه المعدة.</p>
            </div>
            <a asp-controller="Maintenance" asp-action="Details" asp-route-equipmentCode="@Model.Code" class="btn btn-outline-primary btn-sm">عرض كسجل صيانة</a>
        </div>

        @if (Model.MaintenanceHistory != null && Model.MaintenanceHistory.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover erp-data-table erp-worksheet-table">
                    <thead>
                        <tr>
                            <th>تاريخ الصيانة</th>
                            <th>الوصف</th>
                            <th class="erp-number">التكلفة</th>
                            <th>تم بواسطة</th>
                            <th>ملاحظات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Model.MaintenanceHistory.OrderByDescending(r => r.MaintenanceDate))
                        {
                            <tr>
                                <td>@record.MaintenanceDate.ToString("yyyy-MM-dd")</td>
                                <td>@record.Description</td>
                                <td class="erp-number">@record.Cost.ToString("N2")</td>
                                <td>@(record.PerformedBy ?? "---")</td>
                                <td>@(record.Notes ?? "---")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا توجد سجلات صيانة لهذه المعدة حتى الآن.</div>
        }
    </section>
</div>
