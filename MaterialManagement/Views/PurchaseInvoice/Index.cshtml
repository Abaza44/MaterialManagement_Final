@model IEnumerable<MaterialManagement.BLL.ModelVM.Invoice.SupplierInvoiceSummaryViewModel>

@{
    ViewData["Title"] = "فواتير الشراء حسب المورد / اليدوي";
}

<div class="erp-page erp-list-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">فواتير الشراء</p>
            <h1>@ViewData["Title"]</h1>
            <p class="erp-table-note">تابع عمليات الموردين المسجلين والموردين اليدويين من شاشة واحدة.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> إنشاء فاتورة شراء</a>
        </div>
    </div>

<div class="erp-party-grid">
    @foreach (var supplier in Model)
    {
        <article class="erp-party-card">
            <div>
                <span class="erp-status-pill @(supplier.SupplierId == 0 ? "erp-status-pill-success" : "")">
                    @(supplier.SupplierId == 0 ? "مورد يدوي" : "مورد مسجل")
                </span>
                <h2>@supplier.SupplierName</h2>
            </div>
            <div class="erp-party-card-metrics">
                <div>
                    <span>عدد العمليات</span>
                    <strong>@supplier.InvoiceCount.ToString("N0")</strong>
                </div>
                <div>
                    <span>إجمالي المستحق</span>
                    <strong class="@(supplier.TotalCredit > 0 ? "text-success" : "")">@supplier.TotalCredit.ToString("N2")</strong>
                </div>
            </div>
            <a asp-action="SupplierInvoices" asp-route-id="@supplier.SupplierId" class="btn btn-outline-primary w-100">
                عرض الفواتير
            </a>
        </article>
    }
</div>
</div>
