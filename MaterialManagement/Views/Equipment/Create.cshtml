@model MaterialManagement.BLL.ModelVM.Equipment.EquipmentCreateModel

@{
    ViewData["Title"] = "إضافة معدة جديدة";
}

<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأصول والتشغيل</p>
            <h1>إضافة معدة جديدة</h1>
            <p class="erp-table-note">سجل بيانات المعدة ومواعيد الصيانة المعروفة إن وجدت.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">العودة للمعدات</a>
    </div>

    <form asp-controller="Equipment" asp-action="Create" method="post" class="erp-panel">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="erp-form-grid">
            <div class="erp-field-wide">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" placeholder="مثال: ضاغط هواء، ماكينة قص" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="PurchaseDate" class="form-label fw-bold"></label>
                <input asp-for="PurchaseDate" class="form-control" type="date" />
                <span asp-validation-for="PurchaseDate" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="LastMaintenanceDate" class="form-label fw-bold"></label>
                <input asp-for="LastMaintenanceDate" class="form-control" type="date" />
                <span asp-validation-for="LastMaintenanceDate" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="NextMaintenanceDate" class="form-label fw-bold"></label>
                <input asp-for="NextMaintenanceDate" class="form-control" type="date" />
                <span asp-validation-for="NextMaintenanceDate" class="text-danger"></span>
            </div>
        </div>

        <div class="erp-form-actions">
            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> حفظ المعدة</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
