@model IEnumerable<MaterialManagement.BLL.ModelVM.Maintenance.MaintenanceRecordViewModel>

@{
    ViewData["Title"] = "سجلات الصيانة";
    var records = Model ?? Enumerable.Empty<MaterialManagement.BLL.ModelVM.Maintenance.MaintenanceRecordViewModel>();
    var totalCost = records.Sum(r => r.Cost);
}

<div class="erp-page erp-list-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success erp-alert">@TempData["Success"]</div>
    }

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">الأصول والتشغيل</p>
            <h1>سجلات الصيانة</h1>
            <p class="erp-table-note">كل عمليات الصيانة المسجلة على المعدات.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Add" class="btn btn-success"><i class="bi bi-plus-circle"></i> إضافة سجل صيانة</a>
            <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-secondary">المعدات</a>
        </div>
    </div>

    <div class="erp-summary-strip">
        <div class="erp-summary-item"><span>عدد السجلات</span><strong>@records.Count()</strong></div>
        <div class="erp-summary-item"><span>إجمالي التكلفة</span><strong>@totalCost.ToString("N2")</strong></div>
        <div class="erp-summary-item"><span>آخر صيانة</span><strong>@(records.Any() ? records.Max(r => r.MaintenanceDate).ToString("yyyy-MM-dd") : "---")</strong></div>
        <div class="erp-summary-item"><span>معدات مشمولة</span><strong>@records.Select(r => r.EquipmentCode).Distinct().Count()</strong></div>
    </div>

    <section class="erp-panel erp-worksheet-panel">
        <div class="erp-panel-header"><h2>حركة الصيانة</h2></div>
        @if (records.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover erp-data-table erp-worksheet-table">
                    <thead>
                        <tr>
                            <th>المعدة</th>
                            <th>تاريخ الصيانة</th>
                            <th>الوصف</th>
                            <th class="erp-number">التكلفة</th>
                            <th>تم بواسطة</th>
                            <th class="text-center">تفاصيل</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in records.OrderByDescending(r => r.MaintenanceDate))
                        {
                            <tr>
                                <td>
                                    <a asp-controller="Equipment" asp-action="Details" asp-route-code="@record.EquipmentCode">
                                        @record.EquipmentName
                                    </a>
                                </td>
                                <td>@record.MaintenanceDate.ToString("yyyy-MM-dd")</td>
                                <td>@record.Description</td>
                                <td class="erp-number">@record.Cost.ToString("N2")</td>
                                <td>@(record.PerformedBy ?? "---")</td>
                                <td class="text-center">
                                    <a asp-action="Details" asp-route-equipmentCode="@record.EquipmentCode" class="btn btn-outline-primary btn-sm">سجل المعدة</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا توجد أي سجلات صيانة حتى الآن.</div>
        }
    </section>
</div>
