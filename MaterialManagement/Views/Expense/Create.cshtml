@model MaterialManagement.BLL.ModelVM.Expense.ExpenseCreateModel

@{
    ViewData["Title"] = "إضافة مصروف جديد";
}

<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">المالية</p>
            <h1>إضافة مصروف جديد</h1>
            <p class="erp-table-note">سجل المصروف مع الفئة وطريقة الدفع والجهة المستفيدة.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
    </div>

    <form asp-action="Create" method="post" class="erp-panel">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="erp-form-grid">
            <div class="erp-field-wide">
                <label asp-for="Description" class="form-label fw-bold"></label>
                <input asp-for="Description" class="form-control" placeholder="مثال: صيانة ماكينة، راتب شهر، نقل خامات" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Amount" class="form-label fw-bold"></label>
                <input asp-for="Amount" class="form-control erp-number" type="number" step="0.01" min="0" />
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="ExpenseDate" class="form-label fw-bold"></label>
                <input asp-for="ExpenseDate" class="form-control" type="date" />
                <span asp-validation-for="ExpenseDate" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="Category" class="form-label fw-bold"></label>
                <select asp-for="Category" class="form-select">
                    <option value="">اختر الفئة</option>
                    <option value="رواتب">رواتب</option>
                    <option value="إيجار">إيجار</option>
                    <option value="مرافق">مرافق</option>
                    <option value="صيانة">صيانة</option>
                    <option value="مواد خام">مواد خام</option>
                    <option value="نقل">نقل</option>
                    <option value="أخرى">أخرى</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div>
                <label asp-for="PaymentMethod" class="form-label fw-bold"></label>
                <select asp-for="PaymentMethod" class="form-select">
                    <option value="">اختر طريقة الدفع</option>
                    <option value="نقدي">نقدي</option>
                    <option value="تحويل بنكي">تحويل بنكي</option>
                    <option value="شيك">شيك</option>
                    <option value="بطاقة ائتمان">بطاقة ائتمان</option>
                </select>
            </div>

            <div>
                <label asp-for="EmployeeId" class="form-label fw-bold"></label>
                <select asp-for="EmployeeId" class="form-select" asp-items="ViewBag.Employees">
                    <option value="">غير مرتبط بموظف</option>
                </select>
            </div>

            <div>
                <label asp-for="PaymentTo" class="form-label fw-bold"></label>
                <input asp-for="PaymentTo" class="form-control" placeholder="اسم الشخص أو الجهة" />
            </div>

            <div class="erp-field-wide">
                <label asp-for="Notes" class="form-label fw-bold"></label>
                <textarea asp-for="Notes" class="form-control" rows="3"></textarea>
            </div>
        </div>

        <div class="erp-form-actions">
            <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> حفظ المصروف</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
