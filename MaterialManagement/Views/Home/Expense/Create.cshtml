@model MaterialManagement.BLL.ModelVM.Expense.ExpenseCreateModel

@{
    ViewData["Title"] = "إضافة مصروف";
}

<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">مسار قديم</p>
            <h1>إضافة المصروف تتم من شاشة المصاريف الرئيسية</h1>
            <p class="erp-table-note">هذا المسار كان نسخة قديمة. استخدم النموذج المعتمد في وحدة المصاريف.</p>
        </div>
    </div>

    <section class="erp-panel">
        <a asp-controller="Expense" asp-action="Create" class="btn btn-success">فتح نموذج إضافة المصروف</a>
        <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
    </section>
</div>
