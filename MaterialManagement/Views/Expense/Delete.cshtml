@model MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel

@{
    ViewData["Title"] = "حذف مصروف";
    ViewData["SupervisorAuthorizationLabel"] = "اعتماد المشرف لحذف المصروف";
    ViewData["SupervisorAuthorizationHint"] = "حذف المصروف يؤثر على التقارير المالية، لذلك يجب اعتماد المشرف قبل التنفيذ.";
}

<div class="erp-page erp-confirm-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">المصاريف</p>
            <h1>حذف مصروف</h1>
            <p class="erp-table-note">راجع تفاصيل المصروف ثم أدخل كلمة مرور المشرف لتأكيد التعطيل.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Index" class="btn btn-outline-secondary">العودة للمصاريف</a>
        </div>
    </div>

    <div class="alert alert-danger erp-alert">
        <h3 class="h5 mb-0">هل أنت متأكد من حذف هذا المصروف؟</h3>
    </div>

<section class="erp-panel erp-danger-zone">
    <h4>تفاصيل المصروف</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">الوصف</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">المبلغ</dt>
        <dd class="col-sm-10">@Model.Amount.ToString("C")</dd>

        <dt class="col-sm-2">التاريخ</dt>
        <dd class="col-sm-10">@Model.ExpenseDate.ToString("yyyy-MM-dd")</dd>

        <dt class="col-sm-2">الفئة</dt>
        <dd class="col-sm-10">@Model.Category</dd>

        <dt class="col-sm-2">طريقة الدفع</dt>
        <dd class="col-sm-10">@Model.PaymentMethod</dd>

        <dt class="col-sm-2">الملاحظات</dt>
        <dd class="col-sm-10">@Model.Notes</dd>

        <dt class="col-sm-2">تاريخ الإضافة</dt>
        <dd class="col-sm-10">@Model.CreatedDate.ToString("yyyy-MM-dd HH:mm")</dd>
    </dl>

    <form asp-action="Delete" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <partial name="_SupervisorPasswordField" />
        <div class="erp-form-actions">
            <button type="submit" class="btn btn-danger">حذف المصروف</button>
            <a asp-action="Index" class="btn btn-outline-secondary">إلغاء</a>
        </div>
    </form>
</section>
</div>
