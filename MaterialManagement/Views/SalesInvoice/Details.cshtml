@model MaterialManagement.BLL.ModelVM.Invoice.SalesInvoiceViewModel
@using MaterialManagement.DAL.Enums
@using System.Collections.Generic
@using System.Globalization
@using System.Linq

@{
    ViewData["Title"] = $"تفاصيل الفاتورة #{Model.InvoiceNumber}";

    var culture = CultureInfo.GetCultureInfo("ar-EG");
    var items = Model.Items ?? new List<MaterialManagement.BLL.ModelVM.Invoice.SalesInvoiceItemViewModel>();
    var totalQuantity = items.Sum(i => i.Quantity);
    var reconstructedNetTotal = Model.PaidAmount + Model.RemainingAmount;
    var discountAmount = Math.Max(Model.TotalAmount - reconstructedNetTotal, 0);
    var netTotal = Model.TotalAmount - discountAmount;
    var remainingStatusClass = Model.RemainingAmount > 0 ? "invoice-status-due" : "invoice-status-paid";
    var remainingStatusText = Model.RemainingAmount > 0 ? "مستحق" : "مدفوعة";
    var isWalkInCustomer = Model.PartyMode == SalesInvoicePartyMode.WalkInCustomer;
    var partyName = isWalkInCustomer ? (Model.OneTimeCustomerName ?? "عميل نقدي") : Model.ClientName;
}

@section Styles {
    <link rel="stylesheet" href="~/css/invoice.css" asp-append-version="true" />
}

<div class="invoice-workbench invoice-document-workbench" dir="rtl">
    <div class="invoice-toolbar invoice-review-toolbar no-print">
        <div>
            <p class="invoice-eyebrow">مراجعة فاتورة بيع</p>
            <h1>فاتورة بيع @Model.InvoiceNumber</h1>
        </div>

        <div class="invoice-toolbar-actions">
            <button type="button" class="btn btn-outline-primary" onclick="window.print()">
                <i class="bi bi-printer"></i> طباعة
            </button>

            @if (Model.RemainingAmount > 0 && Model.ClientId.HasValue)
            {
                <a asp-controller="Payment"
                   asp-action="AddClientPayment"
                   asp-route-clientId="@Model.ClientId"
                   asp-route-invoiceId="@Model.Id"
                   class="btn btn-primary">
                    <i class="bi bi-plus-circle"></i> إضافة دفعة
                </a>
            }

            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-list-ul"></i> العودة للفواتير
            </a>
        </div>
    </div>

    <article class="invoice-document" aria-label="تفاصيل فاتورة البيع">
        <header class="invoice-document-header">
            <div class="invoice-document-brand">
                <p class="invoice-eyebrow">فاتورة بيع</p>
                <h2>@Model.InvoiceNumber</h2>
                <span>تاريخ الفاتورة: @Model.InvoiceDate.ToString("yyyy/MM/dd", culture)</span>
            </div>

            <div class="invoice-document-status @remainingStatusClass">
                <span>@remainingStatusText</span>
                <strong>@Model.RemainingAmount.ToString("N2", culture)</strong>
                <small>ج.م متبقي</small>
            </div>
        </header>

        <section class="invoice-document-meta" aria-label="بيانات الفاتورة">
            <div class="invoice-meta-item">
                <span>@(isWalkInCustomer ? "العميل النقدي" : "العميل")</span>
                <strong>
                    @if (Model.ClientId.HasValue)
                    {
                        <a asp-controller="Client"
                           asp-action="Details"
                           asp-route-id="@Model.ClientId"
                           class="invoice-document-link">
                            @partyName
                        </a>
                    }
                    else
                    {
                        <span>@partyName</span>
                    }
                </strong>
                @if (isWalkInCustomer && !string.IsNullOrWhiteSpace(Model.OneTimeCustomerPhone))
                {
                    <small class="invoice-meta-note">@Model.OneTimeCustomerPhone</small>
                }
            </div>

            <div class="invoice-meta-item">
                <span>عدد البنود</span>
                <strong>@items.Count.ToString("N0", culture)</strong>
            </div>

            <div class="invoice-meta-item">
                <span>إجمالي الكميات</span>
                <strong>@totalQuantity.ToString("N2", culture)</strong>
            </div>

            <div class="invoice-meta-item">
                <span>صافي الفاتورة</span>
                <strong>@netTotal.ToString("N2", culture) ج.م</strong>
            </div>
        </section>

        <section class="invoice-document-lines" aria-label="بنود الفاتورة">
            <div class="invoice-document-section-heading">
                <h3>بنود الفاتورة</h3>
                <span>@items.Count.ToString("N0", culture) بند</span>
            </div>

            <div class="invoice-grid-wrap invoice-review-grid-wrap">
                <table class="invoice-entry-grid invoice-review-grid">
                    <thead>
                        <tr>
                            <th class="invoice-row-index">#</th>
                            <th>كود المادة</th>
                            <th>المادة</th>
                            <th class="invoice-number-column">الكمية</th>
                            <th class="invoice-number-column">سعر الوحدة</th>
                            <th class="invoice-number-column">إجمالي البند</th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (var i = 0; i < items.Count; i++)
                        {
                            var item = items[i];
                            <tr>
                                <td class="invoice-row-index">@(i + 1)</td>
                                <td>@(string.IsNullOrWhiteSpace(item.MaterialCode) ? "-" : item.MaterialCode)</td>
                                <td>@item.MaterialName</td>
                                <td class="invoice-number-column">@item.Quantity.ToString("N2", culture)</td>
                                <td class="invoice-number-column">@item.UnitPrice.ToString("N2", culture)</td>
                                <td class="invoice-number-column invoice-line-total-text">@item.TotalPrice.ToString("N2", culture)</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3">إجمالي البنود</td>
                            <td class="invoice-number-column">@totalQuantity.ToString("N2", culture)</td>
                            <td></td>
                            <td class="invoice-number-column">@Model.TotalAmount.ToString("N2", culture)</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </section>

        <section class="invoice-review-bottom" aria-label="ملخص الفاتورة">
            <div class="invoice-notes-panel">
                <h3>ملاحظات</h3>
                @if (!string.IsNullOrWhiteSpace(Model.Notes))
                {
                    <p>@Model.Notes</p>
                }
                else
                {
                    <p class="invoice-muted-text">لا توجد ملاحظات مسجلة على هذه الفاتورة.</p>
                }
            </div>

            <aside class="invoice-summary-panel" aria-label="إجماليات الفاتورة">
                <div class="invoice-summary-row">
                    <span>الإجمالي قبل الخصم</span>
                    <strong>@Model.TotalAmount.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row">
                    <span>الخصم</span>
                    <strong>@discountAmount.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row invoice-summary-row-total">
                    <span>الصافي</span>
                    <strong>@netTotal.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row">
                    <span>المدفوع</span>
                    <strong>@Model.PaidAmount.ToString("N2", culture) ج.م</strong>
                </div>
                <div class="invoice-summary-row invoice-summary-row-due">
                    <span>المتبقي</span>
                    <strong>@Model.RemainingAmount.ToString("N2", culture) ج.م</strong>
                </div>
            </aside>
        </section>

        @if (Model.RemainingAmount > 0 && Model.ClientId.HasValue)
        {
            <section class="invoice-payment-callout no-print" aria-label="إجراء على المتبقي">
                <div>
                    <strong>يوجد مبلغ متبقٍ على هذه الفاتورة.</strong>
                    <p>سجل دفعة مرتبطة بهذه الفاتورة لتحديث المدفوع والمتبقي.</p>
                </div>
                <a asp-controller="Payment"
                   asp-action="AddClientPayment"
                   asp-route-clientId="@Model.ClientId"
                   asp-route-invoiceId="@Model.Id"
                   class="btn btn-success">
                    تسجيل دفعة
                </a>
            </section>
        }
    </article>
</div>
