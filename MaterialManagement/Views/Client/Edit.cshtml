@model MaterialManagement.BLL.ModelVM.Client.ClientUpdateModel

@{
    ViewData["Title"] = "تعديل عميل";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="erp-page erp-form-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">العملاء</p>
            <h1>تعديل عميل</h1>
        </div>
    </div>

    <form asp-action="Edit" method="post" class="erp-panel">
        <div class="erp-form-grid">
        <div>
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="erp-field-wide">
            <label asp-for="Address" class="form-label"></label>
            <input asp-for="Address" class="form-control" />
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>

        <div>
            <label asp-for="Balance" class="form-label"></label>
            <input asp-for="Balance" class="form-control" />
            <span asp-validation-for="Balance" class="text-danger"></span>
        </div>

        <div class="form-check align-self-end">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label">نشط</label>
        </div>
        </div>

        <div class="erp-form-actions">
            <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> تحديث</button>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
        </div>
    </form>
</div>
