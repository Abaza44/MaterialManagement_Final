@{
    ViewData["Title"] = "الصفحة الرئيسية";
}

<div class="erp-page">

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">نظام إدارة المواد</p>
            <h1>مساحة التشغيل اليومية</h1>
            <p class="erp-table-note">إدارة المخزون، الفواتير، الحسابات، والحجوزات من نفس الواجهة.</p>
        </div>
        <div class="erp-actions">
            <a class="btn btn-lg btn-primary" asp-controller="Home" asp-action="Index">دخول إلى لوحة التحكم</a>
        </div>
    </div>

    <div class="erp-workflow-grid">
        <a asp-controller="Material" asp-action="Index" class="erp-action-card">
            <i class="bi bi-box-seam"></i>
            <strong>إدارة المخزون</strong>
            <span>تسجيل المواد ومتابعة الكميات المتاحة والمحجوزة.</span>
        </a>

        <div class="erp-action-card">
            <i class="bi bi-people"></i>
            <strong>العملاء والموردين</strong>
            <span>إدارة الحسابات والأرصدة من شاشات تشغيلية واضحة.</span>
            <div class="erp-actions mt-auto">
                <a asp-controller="Client" asp-action="Index" class="btn btn-outline-secondary btn-sm">العملاء</a>
                <a asp-controller="Supplier" asp-action="Index" class="btn btn-outline-secondary btn-sm">الموردين</a>
            </div>
        </div>

        <div class="erp-action-card">
            <i class="bi bi-receipt"></i>
            <strong>الفواتير</strong>
            <span>إنشاء وتتبع فواتير البيع والشراء والمرتجعات.</span>
            <div class="erp-actions mt-auto">
                <a asp-controller="SalesInvoice" asp-action="Index" class="btn btn-outline-success btn-sm">فواتير البيع</a>
                <a asp-controller="PurchaseInvoice" asp-action="Index" class="btn btn-outline-success btn-sm">فواتير الشراء</a>
            </div>
        </div>

        <div class="erp-action-card">
            <i class="bi bi-wallet2"></i>
            <strong>المالية</strong>
            <span>تسجيل التحصيلات والدفعات والمصاريف اليومية.</span>
            <div class="erp-actions mt-auto">
                <a asp-controller="Payment" asp-action="AddClientPayment" class="btn btn-outline-info btn-sm">إضافة تحصيل</a>
                <a asp-controller="Expense" asp-action="Index" class="btn btn-outline-info btn-sm">المصاريف</a>
            </div>
        </div>

        <div class="erp-action-card">
            <i class="bi bi-tools"></i>
            <strong>العمليات والصيانة</strong>
            <span>متابعة المعدات وسجلات الصيانة ومواعيد التشغيل.</span>
            <div class="erp-actions mt-auto">
                <a asp-controller="Equipment" asp-action="Index" class="btn btn-outline-dark btn-sm">المعدات</a>
                <a asp-controller="Maintenance" asp-action="Index" class="btn btn-outline-dark btn-sm">الصيانة</a>
            </div>
        </div>

        <a asp-controller="Report" asp-action="AccountStatement" class="erp-action-card">
            <i class="bi bi-file-earmark-bar-graph"></i>
            <strong>التقارير</strong>
            <span>كشوف حساب وحركة صنف وأرباح بصيغة مناسبة للطباعة.</span>
        </a>
    </div>

</div>
