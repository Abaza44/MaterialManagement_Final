@model IEnumerable<MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel>

@{
    ViewData["Title"] = "تقرير المصاريف";
    var expenses = Model ?? Enumerable.Empty<MaterialManagement.BLL.ModelVM.Expense.ExpenseViewModel>();
    var rawStats = ViewBag.CategoryStats as System.Collections.IEnumerable;
    var categoryStats = rawStats == null ? new List<dynamic>() : rawStats.Cast<dynamic>().ToList();
    var monthlyTotal = (decimal)(ViewBag.MonthlyTotal ?? 0m);
    var yearlyTotal = (decimal)(ViewBag.YearlyTotal ?? 0m);
}

<div class="erp-page erp-report-page erp-list-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">التقارير</p>
            <h1>تقرير المصاريف</h1>
            <p class="erp-table-note">ملخص مصاريف @((string?)ViewBag.CurrentMonth ?? "الشهر الحالي") حسب الفئة والتفاصيل.</p>
        </div>
        <div class="erp-actions no-print">
            <button type="button" class="btn btn-outline-primary" onclick="window.print()">طباعة</button>
            <a asp-action="Index" class="btn btn-outline-secondary">عرض كل المصاريف</a>
        </div>
    </div>

    <div class="erp-summary-strip erp-report-summary-strip">
        <div class="erp-summary-item"><span>إجمالي الشهر</span><strong>@monthlyTotal.ToString("N2")</strong></div>
        <div class="erp-summary-item"><span>إجمالي السنة</span><strong>@yearlyTotal.ToString("N2")</strong></div>
        <div class="erp-summary-item"><span>عدد مصاريف الشهر</span><strong>@expenses.Count()</strong></div>
        <div class="erp-summary-item"><span>تاريخ التقرير</span><strong>@DateTime.Today.ToString("yyyy-MM-dd")</strong></div>
    </div>

    <section class="erp-panel erp-worksheet-panel">
        <div class="erp-panel-header"><h2>توزيع المصاريف حسب الفئة</h2></div>
        @if (categoryStats.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover erp-data-table erp-report-table erp-worksheet-table">
                    <thead>
                        <tr>
                            <th>الفئة</th>
                            <th class="erp-number">الإجمالي</th>
                            <th>النسبة</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (dynamic stat in categoryStats)
                        {
                            var total = Convert.ToDecimal(stat.Total);
                            var percentage = Convert.ToDecimal(stat.Percentage);
                            var width = Math.Min(100, Math.Max(0, percentage));
                            <tr>
                                <td>@stat.Category</td>
                                <td class="erp-number">@total.ToString("N2")</td>
                                <td>
                                    <div class="progress" style="height: 1.5rem;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: @width.ToString("F0", System.Globalization.CultureInfo.InvariantCulture)%;"
                                             aria-valuenow="@width.ToString("F0")"
                                             aria-valuemin="0"
                                             aria-valuemax="100">
                                            @percentage.ToString("F1")%
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا توجد بيانات فئات لعرضها.</div>
        }
    </section>

    <section class="erp-panel erp-worksheet-panel">
        <div class="erp-panel-header"><h2>تفاصيل مصاريف الشهر</h2></div>
        @if (expenses.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover erp-data-table erp-report-table erp-worksheet-table">
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الوصف</th>
                            <th>الفئة</th>
                            <th class="erp-number">المبلغ</th>
                            <th>طريقة الدفع</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in expenses.OrderByDescending(e => e.ExpenseDate))
                        {
                            <tr>
                                <td>@item.ExpenseDate.ToString("yyyy-MM-dd")</td>
                                <td>@item.Description</td>
                                <td>@(item.Category ?? "---")</td>
                                <td class="erp-number">@item.Amount.ToString("N2")</td>
                                <td>@(item.PaymentMethod ?? "---")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="erp-empty-state">لا توجد مصاريف في الفترة الحالية.</div>
        }
    </section>
</div>
