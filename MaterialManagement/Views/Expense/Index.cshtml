@{
    ViewData["Title"] = "إدارة المصاريف";
}

<div class="erp-page">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success erp-alert">@TempData["Success"]</div>
    }

    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">المالية</p>
            <h1>@ViewData["Title"]</h1>
            <p class="erp-table-note">راجع المصاريف، صفها، وافتح التفاصيل قبل التعديل أو الحذف.</p>
        </div>
        <div class="erp-actions">
            <a asp-action="Report" class="btn btn-outline-primary"><i class="bi bi-file-earmark-bar-graph"></i> تقرير المصاريف</a>
            <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> إضافة مصروف جديد</a>
        </div>
    </div>

    <section class="erp-panel erp-filter-panel">
        <div class="erp-panel-header"><h2><i class="bi bi-funnel"></i> فلاتر المصاريف</h2></div>
        <div class="erp-inline-toolbar">
            <div>
                <label for="categoryFilter" class="form-label">الفئة</label>
                <select id="categoryFilter" class="form-select">
                    <option value="" selected>كل الفئات</option>
                    <option value="رواتب">رواتب</option>
                    <option value="إيجار">إيجار</option>
                    <option value="مرافق">مرافق</option>
                    <option value="صيانة">صيانة</option>
                    <option value="مواد خام">مواد خام</option>
                    <option value="نقل">نقل</option>
                    <option value="أخرى">أخرى</option>
                </select>
            </div>
            <div>
                <label for="startDateFilter" class="form-label">من تاريخ</label>
                <input type="date" id="startDateFilter" class="form-control" />
            </div>
            <div>
                <label for="endDateFilter" class="form-label">إلى تاريخ</label>
                <input type="date" id="endDateFilter" class="form-control" />
            </div>
            <button id="applyFilterBtn" type="button" class="btn btn-primary"><i class="bi bi-search"></i> تصفية</button>
            <div class="erp-form-action-total">
                <span class="erp-table-note">الإجمالي المصفى</span>
                <strong id="totalFilteredAmount" class="erp-number d-block">0.00</strong>
            </div>
        </div>
    </section>

    <section class="erp-panel">
        <div class="erp-panel-header"><h2>قائمة المصاريف</h2></div>
        <div class="table-responsive">
            <table class="table table-hover align-middle erp-data-table" id="expensesTable" style="width:100%">
                <thead>
                    <tr>
                        <th>التاريخ</th>
                        <th>الوصف</th>
                        <th class="erp-number">المبلغ</th>
                        <th>الفئة</th>
                        <th>مدفوع إلى</th>
                        <th class="text-center">العمليات</th>
                    </tr>
                </thead>
            </table>
        </div>
    </section>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            var expensesDataTable = $('#expensesTable').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": {
                    "url": "/Expense/LoadData",
                    "type": "POST",
                    "data": function (d) {
                        d.categoryFilter = $('#categoryFilter').val();
                        d.startDate = $('#startDateFilter').val();
                        d.endDate = $('#endDateFilter').val();
                    },
                    "dataSrc": function (json) {
                        $('#totalFilteredAmount').text((json.totalFilteredAmount || '0.00') + ' ج.م');
                        return json.data;
                    }
                },
                "columns": [
                    { "data": "expenseDate", "render": function(data) { return data ? new Date(data).toLocaleDateString('ar-EG') : '---'; } },
                    { "data": "description" },
                    { "data": "amount", "className": "erp-number", "render": $.fn.dataTable.render.number(',', '.', 2), "orderable": true },
                    { "data": "category", "defaultContent": "---" },
                    {
                        "data": null,
                        "render": function(data, type, row) {
                            return row.employeeName || row.paymentTo || '---';
                        },
                        "orderable": false
                    },
                    {
                        "data": "id",
                        "render": function (data) {
                            return `<div class="erp-table-actions">
                                        <a href="/Expense/Details/${data}" class="btn btn-outline-primary btn-sm">تفاصيل</a>
                                        <a href="/Expense/Edit/${data}" class="btn btn-outline-warning btn-sm">تعديل</a>
                                        <a href="/Expense/Delete/${data}" class="btn btn-outline-danger btn-sm">حذف</a>
                                    </div>`;
                        },
                        "orderable": false,
                        "searchable": false
                    }
                ],
                "language": window.erpDataTablesArabic,
                "order": [[0, "desc"]]
            });

            $('#applyFilterBtn, #categoryFilter').on('click change', function() {
                expensesDataTable.draw();
            });
        });
    </script>
}
