@model MaterialManagement.BLL.ModelVM.Client.ClientViewModel

@{
    ViewData["Title"] = "تفاصيل عميل";
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
<div class="erp-page erp-narrow-page">
    <div class="erp-page-header">
        <div>
            <p class="erp-eyebrow">العملاء</p>
            <h1>@Model.Name</h1>
        </div>
        <div class="erp-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning"><i class="bi bi-pencil"></i> تعديل</a>
            <a asp-action="Index" class="btn btn-outline-secondary">رجوع</a>
        </div>
    </div>

    <div class="erp-panel">
        <div class="erp-panel-header"><h2>بيانات العميل</h2></div>
        <div class="erp-detail-grid">
            <div class="erp-detail-item"><span>الاسم</span><strong>@Model.Name</strong></div>
            <div class="erp-detail-item"><span>الهاتف</span><strong>@(Model.Phone ?? "-")</strong></div>
            <div class="erp-detail-item erp-field-wide"><span>العنوان</span><strong>@(Model.Address ?? "-")</strong></div>
            <div class="erp-detail-item"><span>الرصيد</span><strong>@Model.Balance.ToString("N2")</strong></div>
            <div class="erp-detail-item"><span>الحالة</span><strong>@(Model.IsActive ? "نشط" : "غير نشط")</strong></div>
        </div>
    </div>
</div>
